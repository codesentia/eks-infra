apiVersion: v1
kind: LimitRange
metadata:
  name: team-{{ team_name }}-limits
  namespace: team-{{ team_name }}
spec:
  limits:
    - type: Container
      default:
        cpu: 500m
        memory: 512Mi
      defaultRequest:
        cpu: 100m
        memory: 128Mi
      max:
        cpu: "2"
        memory: 4Gi
