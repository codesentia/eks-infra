apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: team-{{ team_name }}-isolation
  namespace: team-{{ team_name }}
spec:
  podSelector: {}
  policyTypes:
    - Ingress
    - Egress
  ingress: []
  egress:
    # Allow DNS resolution to kube-dns
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: kube-system
      ports:
        - protocol: UDP
          port: 53
    # Allow traffic within same namespace
    - to:
        - podSelector: {}
    # Allow traffic to Kubernetes API server
    - to:
        - namespaceSelector: {}
      ports:
        - protocol: TCP
          port: 443
